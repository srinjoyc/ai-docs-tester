# Test wallet for Arb Sepolia E2E grading
# Address: 0xd5777B750437A21B0f22A32e7e6Bc2E82289172D
TEST_WALLET_PRIVATE_KEY=0x<your_arb_sepolia_test_private_key>

# ZeroDev project ID for Arb Sepolia (https://dashboard.zerodev.app)
# When set, E2E tests submit real UserOperations; otherwise they run in mock mode.
ZERODEV_PROJECT_ID=<your_zerodev_project_id>

# Override bundler/paymaster URLs (optional — defaults derived from project ID)
# BUNDLER_URL=https://rpc.zerodev.app/api/v2/bundler/<project_id>
# PAYMASTER_URL=https://rpc.zerodev.app/api/v2/paymaster/<project_id>
